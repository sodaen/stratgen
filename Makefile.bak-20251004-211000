# =========================
# StratGen — Make Targets
# =========================
# Variablen (bei Bedarf zur Laufzeit überschreiben, z.B. HOST=0.0.0.0 make run)
HOST ?= 127.0.0.1
PORT ?= 8000
BASE := http://$(HOST):$(PORT)

VENV := .venv
PY   := $(VENV)/bin/python
PIP  := $(VENV)/bin/pip

# Gunicorn (Staging)
GUNI_WORKERS ?= 2
GUNI_THREADS ?= 1
GUNI_TIMEOUT ?= 120
GUNI_BIND    ?= 127.0.0.1:8000
GUNI_LOG     ?= /tmp/stratgen-staging.log
GUNI_PID     ?= /tmp/stratgen-staging.pid

# Dev (Uvicorn)
DEV_LOG ?= /tmp/stratgen-dev.log
DEV_PID ?= /tmp/stratgen-dev.pid

# Qdrant Docker
QDRANT_NAME ?= qdrant
QDRANT_IMG  ?= qdrant/qdrant:v1.9.2
QDRANT_PORT ?= 6333
QDRANT_VOL  ?= $(HOME)/qdrant_storage

# --------------------------------
# Übersicht
# --------------------------------
list:
	@echo "Kern:         ensure_venv run"
	@echo "Dev:          start_dev logs_dev stop_dev"
	@echo "Staging:      start_staging logs_staging stop_staging restart_staging"
	@echo "Live:         start_live stop_live restart_live status_live logs_live edit_live"
	@echo "Qdrant:       qdrant_start qdrant_stop qdrant_restart qdrant_logs qdrant_ready qdrant_collections qdrant_count"
	@echo "Ollama:       ollama_status ollama_logs ollama_start ollama_stop ollama_restart"
	@echo "Extras:       ensure_outline ideas deck"
	@echo "NEU/Diag:     health_api health_qdrant health_ollama health diag clean_tmp ingest_acme preview_first restart_stack rebuild_venv freeze"

# --------------------------------
# Kern
# --------------------------------
ensure_venv:
	test -d $(VENV) || python3 -m venv $(VENV)
	$(PIP) install -U pip wheel
	if [ -f requirements.txt ]; then $(PIP) install -r requirements.txt; else \
		$(PIP) install fastapi "uvicorn[standard]" pydantic httpx qdrant-client python-pptx sentence-transformers; \
	fi

run: ensure_venv
	HOST=$(HOST) PORT=$(PORT) $(PY) -m uvicorn backend.api:app --host $(HOST) --port $(PORT) --reload

# --------------------------------
# Dev (Uvicorn im Hintergrund)
# --------------------------------
start_dev: ensure_venv
	@echo "Starte Dev (Uvicorn) ..."
	nohup $(PY) -m uvicorn backend.api:app --host $(HOST) --port $(PORT) --reload >$(DEV_LOG) 2>&1 &
	echo $$! > $(DEV_PID)
	@echo "PID: $$(cat $(DEV_PID))  Logs: $(DEV_LOG)"

logs_dev:
	tail -f $(DEV_LOG)

stop_dev:
	@if [ -f $(DEV_PID) ]; then \
		echo "Stoppe Dev PID $$(cat $(DEV_PID))"; \
		kill $$(cat $(DEV_PID)) || true; rm -f $(DEV_PID); \
	else echo "Kein Dev-PID gefunden"; fi

# --------------------------------
# Staging (Gunicorn detached)
# --------------------------------
start_staging: ensure_venv
	@echo "Starte Staging (Gunicorn) ..."
	nohup $(PY) -m gunicorn backend.api:app -w $(GUNI_WORKERS) --threads $(GUNI_THREADS) --timeout $(GUNI_TIMEOUT) --bind $(GUNI_BIND) >$(GUNI_LOG) 2>&1 &
	echo $$! > $(GUNI_PID)
	@echo "PID: $$(cat $(GUNI_PID))  Logs: $(GUNI_LOG)"

logs_staging:
	tail -f $(GUNI_LOG)

stop_staging:
	@if [ -f $(GUNI_PID) ]; then \
		echo "Stoppe Staging PID $$(cat $(GUNI_PID))"; \
		kill $$(cat $(GUNI_PID)) || true; rm -f $(GUNI_PID); \
	else echo "Kein Staging-PID gefunden"; fi

restart_staging: stop_staging start_staging

# --------------------------------
# Live (systemd)
# --------------------------------
start_live:
	sudo systemctl start stratgen

stop_live:
	sudo systemctl stop stratgen

restart_live:
	sudo systemctl daemon-reload
	sudo systemctl restart stratgen

status_live:
	systemctl status stratgen --no-pager

logs_live:
	journalctl -u stratgen -f -n 100

edit_live:
	sudo systemctl edit stratgen

# --------------------------------
# Qdrant (Docker)
# --------------------------------
qdrant_start:
	mkdir -p $(QDRANT_VOL)
	@if docker ps --format '{{.Names}}' | grep -qx $(QDRANT_NAME); then \
		echo "Qdrant läuft bereits."; \
	else \
		if docker ps -a --format '{{.Names}}' | grep -qx $(QDRANT_NAME); then \
			echo "Starte existierenden Container ..."; docker start $(QDRANT_NAME); \
		else \
			echo "Erzeuge neuen Container ..."; \
			docker run -d --name $(QDRANT_NAME) -p $(QDRANT_PORT):6333 -v $(QDRANT_VOL):/qdrant/storage $(QDRANT_IMG); \
		fi \
	fi

qdrant_stop:
	docker stop $(QDRANT_NAME) || true

qdrant_restart: qdrant_stop qdrant_start

qdrant_logs:
	docker logs -f $(QDRANT_NAME)

qdrant_ready:
	@for i in $$(seq 1 20); do \
		if curl -fsS http://127.0.0.1:$(QDRANT_PORT)/readyz >/dev/null; then echo "Qdrant ready"; exit 0; fi; \
		echo "...warte auf Qdrant ($$i)"; sleep 1; \
	done; exit 1

qdrant_collections:
	curl -s http://127.0.0.1:$(QDRANT_PORT)/collections | jq .

qdrant_count:
	curl -s -X POST http://127.0.0.1:$(QDRANT_PORT)/collections/strategies/points/count | jq .

# --------------------------------
# Ollama (systemd)
# --------------------------------
ollama_status:
	systemctl is-active ollama || true
	systemctl status ollama --no-pager || true
	@echo "Umgebungen:"
	systemctl show -p Environment ollama || true

ollama_logs:
	journalctl -u ollama -f -n 100

ollama_start:
	sudo systemctl start ollama

ollama_stop:
	sudo systemctl stop ollama

ollama_restart:
	sudo systemctl restart ollama

# --------------------------------
# Extras / Content
# --------------------------------
ensure_outline:
	curl -s -X POST $(BASE)/outline/suggest \
	  -H "Content-Type: application/json" \
	  -d '{"customer_name":"Acme GmbH","project_title":"Q4 Strategy","scope":"Marketingstrategie & Social Media","market":"Elektronikhandel","region":"DACH","min_slides":12}' \
	  | tee /tmp/outline_raw.json >/dev/null
	@echo "Outline gespeichert: /tmp/outline_raw.json"

ideas: ensure_outline
	@TOPIC=$$(jq -r '.agenda[0].topic' /tmp/outline_raw.json); \
	SUB=$$(jq -r '.agenda[0].subtopics[0] // empty' /tmp/outline_raw.json); \
	jq -n --arg t "$$TOPIC" --arg s "$$SUB" \
	  '{ customer_name:"Acme GmbH", topic:$$t, mode:"facts", brief:{ scope:"Marketingstrategie & Social Media", market:"Elektronikhandel", region:"DACH"} } \
	   + ( ($$s|length)>0 ? {subtopic:$$s} : {} )' \
	  | tee /tmp/preview_req.json >/dev/null; \
	curl -s -X POST $(BASE)/content/preview -H "Content-Type: application/json" \
	  --data-binary @/tmp/preview_req.json | jq '{ok, bullets:(.bullets[:5]), context:(.context[:2])}'

deck: ensure_venv ensure_outline
	$(PY) - <<'PY'
import json, datetime
from pathlib import Path
import httpx
from pptx import Presentation
from pptx.util import Pt

BASE = "$(BASE)"
o = json.loads(Path("/tmp/outline_raw.json").read_text())
agenda = o.get("agenda", [])
brief = {"scope":"Marketingstrategie & Social Media","market":"Elektronikhandel","region":"DACH"}

prs = Presentation()
def add_slide(title, bullets):
    layout = prs.slide_layouts[1]
    s = prs.slides.add_slide(layout)
    s.shapes.title.text = title
    tb = s.placeholders[1].text_frame
    tb.clear()
    for b in bullets or []:
        p = tb.add_paragraph()
        p.text = b
        p.font.size = Pt(18)

for item in agenda:
    topic = item.get("topic","")
    subs = item.get("subtopics") or [""]
    for sub in subs:
        req = {"customer_name":"Acme GmbH","topic":topic,"mode":"facts","brief":brief}
        if sub: req["subtopic"]=sub
        try:
            r = httpx.post(f"{BASE}/content/preview", json=req, timeout=60)
            data = r.json()
            bullets = data.get("bullets") or []
        except Exception:
            bullets = []
        title = topic + (f" — {sub}" if sub else "")
        add_slide(title, bullets[:6])

out = Path("/tmp/strategy_deck.pptx")
prs.save(out)
print(f"Deck: {out}")
PY
	@ls -lh /tmp/strategy_deck.pptx

# --------------------------------
# NEU: Diagnose & Utilities
# --------------------------------
health_api:
	@echo "[API] $(BASE)/openapi.json -> $$(curl -s -o /dev/null -w '%{http_code}' $(BASE)/openapi.json)"

health_qdrant:
	@echo "[QDRANT] readyz -> $$(curl -s -o /dev/null -w '%{http_code}' http://127.0.0.1:$(QDRANT_PORT)/readyz)"
	@echo "[QDRANT] collections:"
	@curl -s http://127.0.0.1:$(QDRANT_PORT)/collections | jq .

health_ollama:
	@echo "[OLLAMA] systemd:"
	@systemctl is-active ollama || true
	@systemctl show -p Environment ollama || true

health: health_api health_qdrant health_ollama
	@echo "Health-Checks ausgeführt."

diag:
	@OUT=/tmp/stratgen_diag.txt; : > $$OUT; \
	echo "== StratGen Diagnose ==" >> $$OUT; \
	date >> $$OUT; \
	echo "\n-- Python --" >> $$OUT; \
	python3 --version >> $$OUT 2>&1 || true; \
	$(PY) - <<'PY' >> $$OUT 2>&1 || true
import pkgutil, sys
def ver(name):
    try:
        m=__import__(name); return name, getattr(m,'__version__','?')
    except Exception as e:
        return name, f"ERR:{e}"
for n in ["fastapi","uvicorn","gunicorn","httpx","qdrant_client","pptx"]:
    print("%s: %s"%ver(n))
PY
	echo "\n-- Processes/Ports --" >> $$OUT; \
	ss -lntp | grep -E ':(8000|6333)\s' >> $$OUT 2>&1 || true; \
	echo "\n-- Qdrant --" >> $$OUT; \
	docker ps -a --format 'table {{.Names}}\t{{.Status}}' | sed -n '1p;/\b$(QDRANT_NAME)\b/p' >> $$OUT 2>&1 || true; \
	curl -s http://127.0.0.1:$(QDRANT_PORT)/readyz >> $$OUT 2>&1 || true; \
	echo "\n-- systemd (ollama/stratgen) --" >> $$OUT; \
	systemctl is-active ollama stratgen >> $$OUT 2>&1 || true; \
	systemctl show -p Environment ollama stratgen >> $$OUT 2>&1 || true; \
	echo "\n-- Logs (tail) --" >> $$OUT; \
	tail -n 100 $(DEV_LOG) $(GUNI_LOG) >> $$OUT 2>&1 || true; \
	echo "Diagnose geschrieben nach $$OUT"; \
	echo "$$OUT"

clean_tmp:
	rm -f /tmp/outline_raw.json /tmp/preview_req.json /tmp/strategy_deck.pptx

ingest_acme:
	curl -s -X POST $(BASE)/datasources/add \
	  -H "Content-Type: application/json" \
	  -d '{"customer_name":"Acme GmbH","entries":[{"type":"file","path":"data/uploads/acme_personas.txt","topics":["Zielgruppe"],"subtopics":["Personas"],"tokens":["b2b","personas"]}]}' \
	  | jq .
	curl -s -X POST $(BASE)/datasources/ingest \
	  -H "Content-Type: application/json" \
	  -d '{"customer_name":"Acme GmbH"}' | jq .

preview_first: ensure_outline
	@TOPIC=$$(jq -r '.agenda[0].topic' /tmp/outline_raw.json); \
	SUB=$$(jq -r '.agenda[0].subtopics[0] // empty' /tmp/outline_raw.json); \
	jq -n --arg t "$$TOPIC" --arg s "$$SUB" \
	  '{ customer_name:"Acme GmbH", topic:$$t, mode:"facts", brief:{ scope:"Marketingstrategie & Social Media", market:"Elektronikhandel", region:"DACH"} } \
	   + ( ($$s|length)>0 ? {subtopic:$$s} : {} )' \
	  | tee /tmp/preview_req.json >/dev/null; \
	curl -s -X POST $(BASE)/content/preview -H "Content-Type: application/json" \
	  --data-binary @/tmp/preview_req.json | jq '{ok, bullets:(.bullets[:5]), context:(.context[:2])}'

restart_stack: qdrant_restart restart_staging

rebuild_venv:
	rm -rf $(VENV)
	$(MAKE) ensure_venv

freeze: ensure_venv
	$(PIP) freeze > requirements_freeze.txt
	@echo "requirements_freeze.txt aktualisiert."
