# =============================================
# StratGen Umgebungsvariablen
# =============================================
# Kopiere diese Datei nach .env und fülle die Werte aus:
#   cp .env.example .env
#
# WICHTIG: .env wird NICHT committed (in .gitignore)
# =============================================

# === App Konfiguration ===
APP_ENV=prod
LOG_LEVEL=info
# _VERSION=1.0.0

# === API Server ===
STRATGEN_HOST=127.0.0.1
STRATGEN_PORT=8011
STRATGEN_INTERNAL_URL=http://127.0.0.1:8011

# CORS (kommasepariert, für Frontend-Entwicklung)
STRATGEN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# === LLM Konfiguration (Lokal) ===
# Für maximalen Datenschutz: Ollama lokal
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
LLM_MODEL=mistral
# Alternativen: llama3, codellama, mixtral

# === LLM Konfiguration (Optional: Cloud) ===
# Nur aktivieren wenn Cloud-LLM gewünscht
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# === Vector Database (Qdrant) ===
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=stratgen_docs
# QDRANT_API_KEY=  # Falls Qdrant Cloud

# === Embeddings ===
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternativen:
# EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# EMBED_MODEL=intfloat/multilingual-e5-small

# === Datenverzeichnisse ===
STRATGEN_DATA_DIR=data
STRATGEN_EXPORTS_DIR=data/exports
STRATGEN_KNOWLEDGE_DIR=data/knowledge

# =============================================
# OPTIONALE EXTERNE DATENQUELLEN
# =============================================
# Diese APIs sind optional. Das System funktioniert
# vollständig lokal ohne diese Keys.
# =============================================

# === Statista API ===
# https://www.statista.com/api/
# STATISTA_API_KEY=

# === Brandwatch API ===
# https://developers.brandwatch.com/
# BRANDWATCH_API_KEY=
# BRANDWATCH_PROJECT_ID=

# === Talkwalker API ===
# https://www.talkwalker.com/api
# TALKWALKER_API_KEY=
# TALKWALKER_PROJECT_ID=

# =============================================
# ENTWICKLUNG & DEBUGGING
# =============================================

# Debug-Modus (mehr Logs)
# DEBUG=1

# Telemetrie (lokal speichern)
TELEMETRY_ENABLED=1

# Preview Cache TTL (Sekunden)
PREVIEW_CACHE_TTL=60

# HTTP Retry Konfiguration
HTTP_RETRY_MAX=3
HTTP_RETRY_BACKOFF=0.5
