# STRATGEN Environment Configuration
# Copy this file to /etc/stratgen.env and adjust values

# === LLM Configuration ===
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_URL=http://localhost:11434

# === API Keys (optional) ===
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# === Unsplash (for images) ===
UNSPLASH_ACCESS_KEY=your_unsplash_key

# === Database ===
QDRANT_URL=http://localhost:6333
REDIS_URL=redis://localhost:6379

# === Security ===
STRATGEN_API_KEY=your_secret_api_key
SECRET_KEY=your_secret_key_for_sessions

# === Paths ===
DATA_DIR=/home/sodaen/stratgen/data
EXPORTS_DIR=/home/sodaen/stratgen/data/exports

# ─── Offline Mode (Sprint 4) ─────────────────────
# Setzt auf true um alle externen HTTP-Calls zu deaktivieren
# (World Bank, OpenAI, Anthropic - Ollama + Qdrant laufen lokal)
STRATGEN_OFFLINE=false

# LLM Provider: ollama (lokal) | openai | anthropic
LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_HOST=http://127.0.0.1:11434

# Optional: OpenAI Fallback
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
