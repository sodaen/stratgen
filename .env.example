# StratGen Environment Configuration
# Kopiere diese Datei nach .env und passe die Werte an.

# ─────────────────────────────────────────────
# LLM PROVIDER
# Mögliche Werte: ollama | openai | anthropic | nemotron
# ─────────────────────────────────────────────
LLM_PROVIDER=ollama
LLM_MODEL=mistral
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024

# ─────────────────────────────────────────────
# OLLAMA (lokal, Privacy-First)
# ─────────────────────────────────────────────
OLLAMA_HOST=http://127.0.0.1:11434

# ─────────────────────────────────────────────
# OPENAI (optional)
# ─────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────
# ANTHROPIC (optional)
# ─────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ─────────────────────────────────────────────
# NVIDIA NEMOTRON 3 SUPER (optional)
# Option A: Nvidia NIM API
# ─────────────────────────────────────────────
# LLM_PROVIDER=nemotron
# NVIDIA_API_KEY=nvapi-...
# NEMOTRON_MODEL=nvidia/nemotron-mini-4b-instruct
# NEMOTRON_HOST=https://integrate.api.nvidia.com/v1

# Option B: Lokal via Ollama
# Zuerst: ollama pull nemotron-mini
# LLM_PROVIDER=nemotron
# NEMOTRON_USE_OLLAMA=true
# NEMOTRON_OLLAMA_MODEL=nemotron-mini

# ─────────────────────────────────────────────
# QDRANT
# ─────────────────────────────────────────────
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=knowledge_base

# ─────────────────────────────────────────────
# DEEP RESEARCH
# ─────────────────────────────────────────────
# TAVILY_API_KEY=tvly-...        # Optional, Fallback: DuckDuckGo
RESEARCH_MAX_QUERIES=10
RESEARCH_MAX_RESULTS=20
RESEARCH_AUTO_INGEST=true

# ─────────────────────────────────────────────
# OFFLINE MODE
# ─────────────────────────────────────────────
STRATGEN_OFFLINE=false

# ─────────────────────────────────────────────
# CUSTOM TEMPLATES
# ─────────────────────────────────────────────
PPTX_TEMPLATE_DIR=data/pptx_templates
PPTX_TEMPLATE_MAX_MB=50
