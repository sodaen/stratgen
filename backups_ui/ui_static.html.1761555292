<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8" />
  <title>StratGen UI v4.1</title>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <style>
    :root { --bg:#0b0d10; --card:#13171c; --muted:#a7b1bd; --fg:#e7edf3; --acc:#5cc8ff; --ok:#55d187; --warn:#f8c14b; --err:#ff6b6b; }
    * { box-sizing: border-box }
    body { margin: 24px; font: 14px/1.5 system-ui, Segoe UI, Roboto, sans-serif; background: var(--bg); color: var(--fg); }
    h1 { font-weight: 700; margin: 0 0 16px; }
    .grid { display:grid; gap:16px; grid-template-columns: repeat(auto-fit,minmax(320px,1fr)); }
    .card { background: var(--card); border: 1px solid #222831; border-radius: 14px; padding: 16px; box-shadow: 0 2px 10px rgba(0,0,0,.25); }
    .row { display:flex; gap:8px; align-items:center; flex-wrap:wrap; }
    input, textarea, select { width:100%; background:#0f1318; border:1px solid #2a313b; border-radius:10px; padding:10px 12px; color:var(--fg); }
    button { background: var(--acc); color:#001018; border:0; border-radius:10px; padding:10px 14px; font-weight:700; cursor:pointer; }
    button.ghost { background: transparent; color: var(--acc); border: 1px solid var(--acc); }
    code, pre { background:#0f1318; color:#bfe6ff; border:1px solid #26303a; border-radius:10px; padding:10px; overflow:auto; }
    .mono { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace; font-size: 12px; }
    .muted { color: var(--muted); }
    .tag { display:inline-block; background:#0f1318; border:1px solid #2a313b; border-radius:999px; padding:4px 8px; font-size:12px; color:var(--muted); }
    .ok { color: var(--ok) } .err { color: var(--err) } .warn { color: var(--warn) }
    .list { max-height:240px; overflow:auto; border:1px dashed #2a313b; border-radius:10px; padding:10px; }
    a { color:#9ad9ff; }
  </style>
</head>
<body>
  <h1>StratGen UI v4.1 <span class="tag">statisch</span></h1>

  <div class="grid">
    <!-- Health / Meta -->
    <div class="card">
      <h3>Health</h3>
      <div class="row">
        <button id="btnHealth">/health</button>
        <button id="btnMetrics" class="ghost">/metrics</button>
        <button id="btnInfo" class="ghost">/debug/info</button>
      </div>
      <pre id="healthOut" class="mono muted" style="margin-top:10px;">noch nix…</pre>
    </div>

    <!-- Compose + Render -->
    <div class="card">
      <h3>Compose → Render → Download</h3>
      <div class="row">
        <input id="customer" placeholder="Kunde" value="Acme GmbH" />
        <input id="topic" placeholder="Topic" value="Go-to-Market 2026 (RAG)" />
      </div>
      <textarea id="query" rows="3" placeholder="Query">ISO27001 SOC2 ROI 90 Tage</textarea>

      <div class="row" style="margin-top:8px;">
        <button id="btnCompose">Compose</button>
        <button id="btnRender" class="ghost" disabled>Render</button>
        <button id="btnDownload" class="ghost" disabled>Download</button>
      </div>

      <div class="row" style="margin-top:8px;">
        <span class="tag">title:</span><span id="titleTag" class="muted">–</span>
        <span class="tag">plan:</span><span id="planLen" class="muted">0</span>
      </div>

      <details style="margin-top:8px;">
        <summary>compose.json</summary>
        <pre id="composeOut" class="mono"></pre>
      </details>
      <details>
        <summary>render.json</summary>
        <pre id="renderOut" class="mono"></pre>
      </details>
    </div>

    <!-- Datasources & Exports -->
    <div class="card">
      <h3>Datasources / Exports</h3>
      <div class="row">
        <input id="customer2" placeholder="Kunde" value="Acme GmbH" />
        <button id="btnListDs" class="ghost">/datasources/list</button>
        <button id="btnStatsDs" class="ghost">/datasources/stats</button>
      </div>
      <div class="row" style="margin-top:6px;">
        <button id="btnListExports">/exports/list</button>
        <button id="btnLatest" class="ghost">/exports/latest</button>
      </div>
      <div style="margin-top:8px;">
        <div class="muted">Exports:</div>
        <div id="exportsList" class="list mono"></div>
      </div>
    </div>

    <!-- Upload & Provider Pull -->
    <div class="card">
      <h3>Upload & Providers</h3>
      <div class="row">
        <input id="fileCustomer" placeholder="Kunde" value="Acme GmbH" />
        <textarea id="fileText" rows="3" placeholder="Kurzer Text, der als Datei ingestet wird…">mini smoke upload</textarea>
      </div>
      <div class="row" style="margin-top:6px;">
        <button id="btnUpload">/research/upload (embed=0)</button>
        <select id="providerSel">
          <option value="statista">statista</option>
          <option value="brandwatch">brandwatch</option>
          <option value="talkwalker">talkwalker</option>
        </select>
        <button id="btnProvStatus" class="ghost">/providers/status</button>
        <button id="btnProvPull" class="ghost">/providers/pull?limit=3</button>
      </div>
      <pre id="provOut" class="mono" style="margin-top:8px;"></pre>
    </div>

    <!-- Download direct -->
    <div class="card">
      <h3>Download (HEAD/GET)</h3>
      <div class="row">
        <input id="dlName" placeholder="Basename z.B. deck-YYYYmmdd-HHMMSS.pptx" />
        <button id="btnHead" class="ghost">HEAD</button>
        <button id="btnGet" class="ghost">GET</button>
      </div>
      <pre id="dlOut" class="mono" style="margin-top:8px;"></pre>
    </div>
  </div>

  <script>
    const API = window.location.origin;

    const qs = sel => document.querySelector(sel);
    const j = v => JSON.stringify(v, null, 2);
    let lastTitle = "";
    let lastPlan = [];
    let lastOut = "";

    async function http(method, path, body, headers={}) {
      const opts = { method, headers: { ...headers } };
      if (body !== undefined) {
        opts.body = typeof body === "string" ? body : JSON.stringify(body);
        opts.headers["Content-Type"] = "application/json";
      }
      const res = await fetch(API + path, opts);
      const txt = await res.text();
      let parsed = null;
      try { parsed = JSON.parse(txt); } catch {}
      return { ok: res.ok, status: res.status, text: txt, json: parsed, headers: res.headers };
    }

    // Health
    qs('#btnHealth').onclick = async ()=>{
      const r = await http('GET','/health');
      qs('#healthOut').textContent = j(r.json ?? r.text);
    };
    qs('#btnMetrics').onclick = async ()=>{
      const r = await fetch(API + '/metrics');
      qs('#healthOut').textContent = await r.text();
    };
    qs('#btnInfo').onclick = async ()=>{
      const r = await http('GET','/debug/info');
      qs('#healthOut').textContent = j(r.json ?? r.text);
    };

    // Compose
    qs('#btnCompose').onclick = async ()=>{
      const customer = qs('#customer').value.trim();
      const topic    = qs('#topic').value.trim();
      const query    = qs('#query').value.trim();
      const r = await http('POST','/content/compose', { customer_name: customer, topic, query });
      qs('#composeOut').textContent = j(r.json ?? r.text);
      const title = r.json?.title || "";
      const plan  = r.json?.plan  || [];
      lastTitle = title; lastPlan = plan;
      qs('#titleTag').textContent = title || "–";
      qs('#planLen').textContent  = Array.isArray(plan) ? plan.length : 0;
      qs('#btnRender').disabled = !title || !Array.isArray(plan);
    };

    // Render
    qs('#btnRender').onclick = async ()=>{
      const out = `data/exports/deck-${new Date().toISOString().replaceAll(':','').replaceAll('-','').slice(0,15)}.pptx`;
      const body = { title: lastTitle, out_path: out, plan: lastPlan };
      const r = await http('POST','/pptx/render', body);
      qs('#renderOut').textContent = j(r.json ?? r.text);
      if (r.json?.ok) {
        lastOut = out;
        qs('#dlName').value = out.split('/').pop();
        qs('#btnDownload').disabled = false;
      }
    };

    // Download Button (aus Render)
    qs('#btnDownload').onclick = async ()=>{
      const bn = qs('#dlName').value.trim();
      if (!bn) return;
      // HEAD:
      const head = await fetch(API + '/exports/download?name=' + encodeURIComponent(bn), { method:'HEAD' });
      const headLines = ['HEAD ' + head.status + ' ' + head.statusText];
      head.headers.forEach((v,k)=> headLines.push(k+': '+v));
      // GET:
      const a = document.createElement('a');
      a.href = API + '/exports/download?name=' + encodeURIComponent(bn);
      a.download = bn;
      a.click();
      qs('#dlOut').textContent = headLines.join('\n');
    };

    // Datasources / Exports
    qs('#btnListDs').onclick = async ()=>{
      const customer = qs('#customer2').value.trim();
      const r = await http('GET', '/datasources/list?customer=' + encodeURIComponent(customer));
      qs('#exportsList').textContent = j(r.json ?? r.text);
    };
    qs('#btnStatsDs').onclick = async ()=>{
      const r = await http('GET', '/datasources/stats');
      qs('#exportsList').textContent = j(r.json ?? r.text);
    };
    qs('#btnListExports').onclick = async ()=>{
      const r = await http('GET', '/exports/list');
      qs('#exportsList').textContent = j(r.json ?? r.text);
    };
    qs('#btnLatest').onclick = async ()=>{
      const r = await http('GET', '/exports/latest');
      qs('#exportsList').textContent = j(r.json ?? r.text);
      const bn = r.json?.latest?.name;
      if (bn) qs('#dlName').value = bn;
    };

    // Upload & Provider
    qs('#btnUpload').onclick = async ()=>{
      const customer = qs('#fileCustomer').value.trim();
      const text = qs('#fileText').value;
      const blob = new Blob([text], { type: 'text/plain' });
      const fd = new FormData();
      const file = new File([blob], 'mini.txt', { type:'text/plain' });
      fd.set('file', file);
      const res = await fetch(API + '/research/upload?customer_name=' + encodeURIComponent(customer) + '&embed=0', {
        method: 'POST', body: fd
      });
      const txt = await res.text();
      qs('#provOut').textContent = txt;
    };

    qs('#btnProvStatus').onclick = async ()=>{
      const r = await http('GET','/providers/status');
      qs('#provOut').textContent = j(r.json ?? r.text);
    };
    qs('#btnProvPull').onclick = async ()=>{
      const prov = qs('#providerSel').value;
      const cust = qs('#fileCustomer').value.trim();
      const r = await http('POST', '/providers/pull?provider=' + encodeURIComponent(prov) + '&customer_name=' + encodeURIComponent(cust) + '&limit=3&embed=0');
      qs('#provOut').textContent = j(r.json ?? r.text);
    };

    // Direkter Download
    qs('#btnHead').onclick = async ()=>{
      const bn = qs('#dlName').value.trim(); if (!bn) return;
      const head = await fetch(API + '/exports/download?name=' + encodeURIComponent(bn), { method:'HEAD' });
      const lines = ['HEAD ' + head.status + ' ' + head.statusText];
      head.headers.forEach((v,k)=> lines.push(k+': '+v));
      qs('#dlOut').textContent = lines.join('\n');
    };
    qs('#btnGet').onclick = async ()=>{
      const bn = qs('#dlName').value.trim(); if (!bn) return;
      const a = document.createElement('a');
      a.href = API + '/exports/download?name=' + encodeURIComponent(bn);
      a.download = bn;
      a.click();
    };
  </script>
</body>
</html>
