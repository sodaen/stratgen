# -*- coding: utf-8 -*-
from __future__ import annotations
from pathlib import Path
from fastapi import APIRouter, Response
from fastapi.responses import HTMLResponse

router = APIRouter(tags=["ui"])
HTML_PATH = Path(__file__).with_name("ui_static.html")

@router.get("/ui", response_class=HTMLResponse)
async def ui_get() -> HTMLResponse:
    try:
        return HTMLResponse(HTML_PATH.read_text(encoding="utf-8"))
    except Exception:
        return HTMLResponse("<!doctype html><title>UI</title><p>ui_static.html fehlt.</p>", status_code=200)

@router.head("/ui")
async def ui_head() -> Response:
    # HEAD soll nie das Script killen
    return Response(status_code=200)
