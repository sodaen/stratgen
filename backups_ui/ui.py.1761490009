# -*- coding: utf-8 -*-
from __future__ import annotations
from fastapi import APIRouter, Response
from fastapi.responses import HTMLResponse

router = APIRouter(tags=["ui"])

HTML = """<!doctype html>
<html lang="de"><head>
<meta charset="utf-8"><title>StratGen UI</title>
<meta name="viewport" content="width=device-width,initial-scale=1">
<style>body{font-family:system-ui,Segoe UI,Roboto,sans-serif;margin:24px}</style>
</head><body>
<h1>StratGen · Mini UI</h1>
<p><a href="/health" target="_blank">Health</a> ·
<a href="/exports/latest" target="_blank">Latest Export</a></p>

<script>
function _basename(name){ return (name||'').split('/').pop(); }
function downloadExport(name){
  const bn = _basename(name);
  if(!bn) return;
  window.location.href = '/exports/download?name=' + encodeURIComponent(bn);
}
</script>
</body></html>"""

@router.get("/ui", response_class=HTMLResponse)
def ui_get():
    return HTML

@router.head("/ui", include_in_schema=False)
def ui_head():
    return Response(status_code=200)

@router.get("/ui/", response_class=HTMLResponse, include_in_schema=False)
def ui_get_slash():
    return HTML

@router.head("/ui/", include_in_schema=False)
def ui_head_slash():
    return Response(status_code=200)
