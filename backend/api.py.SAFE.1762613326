# -*- coding: utf-8 -*-
from __future__ import annotations

# Zentrale FastAPI-App: Router nur EINMAL einhängen, defensiv & deutsch.
from fastapi import FastAPI
from backend.datasources_api import router as datasources_router
from backend.knowledge_answer_api import router as knowledge_answer_router
from backend.research_api import router as research_router
from backend.enrich_api import router as enrich_router
from backend.exports_api import router as exports_router
from fastapi.middleware.cors import CORSMiddleware
from backend.pptx_api import router as pptx_router
from backend.projects_api import router as projects_router

app = FastAPI(title="Stratgen API", version="1.0")





app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"], allow_credentials=True,
    allow_methods=["*"], allow_headers=["*"],
)

# --- CORS (locker; bei Bedarf enger einstellen) ---
# --- optionale Middlewares (Observability/Security), defensiv importiert ---
try:
    from backend.observability import router as obs_router, RequestLoggerMiddleware, RequestIDMiddleware
    app.add_middleware(RequestIDMiddleware)
    app.add_middleware(RequestLoggerMiddleware)
    app.include_router(obs_router)
except Exception as e:
    print("WARN: observability nicht aktiv:", e)

try:
    from backend.security import SecurityHeadersMiddleware
    app.add_middleware(SecurityHeadersMiddleware)
except Exception as e:
    print("WARN: security middleware nicht aktiv:", e)

# --- Kernrouter, die vorhanden sein sollten ---
# (defensiv: wenn Import scheitert -> weiter)
def _try_import_router(module_path: str):
    try:
        mod = __import__(module_path, fromlist=['router'])
        if hasattr(mod, "router"):
            app.include_router(getattr(mod, "router"))
            return True
        print(f"WARN: {module_path} hat keinen 'router'")
    except Exception as e:
        print(f"WARN: include_router fehlgeschlagen für {module_path}:", e)
    return False

# Pflicht-Router
for m in [
    "backend.projects_api",
    "backend.pptx_api",
    
    "backend.exports_api",
]:
    _try_import_router(m)

# Optionale/Agent-Router (einmalig mounten!)
optional_modules = [
    "backend.briefs_api",
    "backend.knowledge_answer_api",
    "backend.metrics_api",
    "backend.plans_api",
    "backend.critique_api",
    "backend.footnotes_api",
    "backend.personas_api",
    "backend.messaging_api",
    "backend.roadmap_api",
    "backend.versioning_api",
    "backend.explain_api",
]
for m in optional_modules:
    _try_import_router(m)

# --- Health-Root ---
@app.get("/")
def root():
    return {"ok": True, "service": "stratgen"}


app.include_router(enrich_router)

app.include_router(research_router)

app.include_router(knowledge_answer_router)

app.include_router(datasources_router)

app.include_router(projects_router)
app.include_router(pptx_router)
app.include_router(exports_router)


@app.get('/health')
def health_root_():
    return {'ok': True, 'service': 'stratgen'}
