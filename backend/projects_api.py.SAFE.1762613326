# -*- coding: utf-8 -*-
from __future__ import annotations
from fastapi import APIRouter, HTTPException, Body
from typing import Any, Dict
from pathlib import Path
import json, time

router = APIRouter(prefix="/projects", tags=["projects"])
DATA_DIR = Path("data")
PJ_DIR = DATA_DIR / "projects"

def _pj_path(project_id: str) -> Path:
    return PJ_DIR / project_id / "project.json"

# ---- Helper (für utils_projects.load_project) ----
def get_project(project_id: str) -> Dict[str, Any]:
    p = _pj_path(project_id)
    if p.exists():
        return json.loads(p.read_text(encoding="utf-8"))
    # Fallback: minimaler Stub (kein 404, da utils ein try/except nutzt)
    return {"id": project_id, "title": f"Project {project_id}", "outline": {"sections": []}}

# ---- Helper (für utils_projects.save_project) ----
def save_project(pj: Dict[str, Any]) -> Dict[str, Any]:
    pid = pj.get("id") or f"proj-{int(time.time())}"
    now = time.time()
    pj["id"] = pid
    pj.setdefault("created_at", now)
    pj["updated_at"] = now

    path = _pj_path(pid)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(pj, ensure_ascii=False, indent=2), encoding="utf-8")
    return {"ok": True, "project": pj}

# ---- Endpoints ----
@router.post("/save")
def save_endpoint(project: Dict[str, Any] = Body(...)) -> Dict[str, Any]:
    return save_project(project)

@router.get("/{project_id}")
def get_endpoint(project_id: str) -> Dict[str, Any]:
    pj = get_project(project_id)
    return {"ok": True, "project": pj}
