# -*- coding: utf-8 -*-
from __future__ import annotations
from fastapi import APIRouter, HTTPException, Query, Response
from fastapi.responses import FileResponse, JSONResponse
from pathlib import Path
from typing import List, Dict, Any

router = APIRouter(prefix="/exports", tags=["exports"])
EXPORTS_DIR = Path("data/exports").resolve()
ALLOWED_EXTS = {".pptx", ".ppt"}  # ggf. erweitern

def _scan_exports() -> List[Path]:
    if not EXPORTS_DIR.exists():
        return []
    files = []
    for p in EXPORTS_DIR.iterdir():
        if p.is_file() and p.suffix.lower() in ALLOWED_EXTS:
            files.append(p)
    # neueste zuerst
    files.sort(key=lambda p: p.stat().st_mtime, reverse=True)
    return files

def _item(p: Path) -> Dict[str, Any]:
    st = p.stat()
    return {
        "name": p.name,
        "path": str(p.relative_to(EXPORTS_DIR.parent)) if EXPORTS_DIR.parent in p.parents else str(p),
        "size": st.st_size,
        "mtime": int(st.st_mtime),
    }

def _safe_path_from_name(name: str) -> Path:
    # Nur Basename akzeptieren (kein Pfad, kein Traversal)
    base = Path(name).name
    full = (EXPORTS_DIR / base).resolve()
    if EXPORTS_DIR not in full.parents or not full.exists():
        raise HTTPException(status_code=404, detail="Not Found")
    if full.suffix.lower() not in ALLOWED_EXTS:
        raise HTTPException(status_code=400, detail="Unsupported file type")
    return full

@router.get("/list")
def list_exports(limit: int = Query(50, ge=1, le=500), offset: int = Query(0, ge=0)):
    files = _scan_exports()
    slice_ = files[offset:offset+limit]
    return JSONResponse({
        "ok": True,
        "count": len(files),
        "items": [_item(p) for p in slice_],
        "offset": offset,
        "limit": limit,
    })

@router.get("/latest")
def latest_export():
    files = _scan_exports()
    if not files:
        # 200 mit ok:false, damit UI/CLI nicht hart fehlschlägt
        return JSONResponse({"ok": False, "latest": None, "message": "no exports found"})
    return JSONResponse({"ok": True, "latest": _item(files[0])})

@router.get("/download")
def download_get(name: str = Query(..., description="Basename der Datei (kein Pfad)")):
    path = _safe_path_from_name(name)
    return FileResponse(
        path,
        media_type="application/vnd.openxmlformats-officedocument.presentationml.presentation",
        filename=path.name,
    )

@router.head("/download")
def download_head(name: str = Query(..., description="Basename der Datei (kein Pfad)")):
    path = _safe_path_from_name(name)
    # Nur Header zurückgeben
    return Response(
        status_code=200,
        headers={
            "Content-Type": "application/vnd.openxmlformats-officedocument.presentationml.presentation",
            "Content-Disposition": f'attachment; filename="{path.name}"',
            "Content-Length": str(path.stat().st_size),
        },
    )
